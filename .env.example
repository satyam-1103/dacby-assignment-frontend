# Hacker News Scraper - Frontend Environment Variables
# Copy this file to .env.local and update with your actual values

# ============================================
# API Configuration
# ============================================

# Backend API Base URL
# Use http://localhost:5000/api for local development
# Use your production URL for deployment
VITE_API_BASE_URL=http://localhost:5000/api

# ============================================
# Optional Configuration
# ============================================

# Application Environment
# Possible values: development, staging, production
# VITE_APP_ENV=development

# ============================================
# Notes:
# ============================================
# 1. All variables must be prefixed with VITE_ to be accessible
#    in the browser via import.meta.env
#
# 2. Never commit the actual .env.local file with sensitive data
#    to version control
#
# 3. For deployment platforms (Vercel, Netlify, etc.),
#    add these variables in your platform's environment settings
#
# 4. Development: Use local backend URL
#    Production: Use deployed backend URL
